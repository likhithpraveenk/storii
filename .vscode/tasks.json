{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dart fix",
      "type": "shell",
      "command": "dart fix --apply",
      "problemMatcher": []
    },
    {
      "label": "dart format",
      "type": "shell",
      "command": "dart format .",
      "problemMatcher": []
    },
    {
      "label": "build_runner build",
      "type": "shell",
      "command": "dart run build_runner build",
      "problemMatcher": []
    },
    {
      "label": "build_runner watch",
      "type": "shell",
      "command": "dart",
      "args": [
        "run",
        "build_runner",
        "watch"
      ],
      "presentation": {
        "revealProblems": "onProblem",
        "reveal": "silent",
        "clear": true,
        "panel": "dedicated"
      },
      "isBackground": true,
      "problemMatcher": "$dart-build_runner"
    }
  ]
}